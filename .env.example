# ============================================================
#  PROMETHEUS — Environment Variable Template
#  Copy this file to .env and fill in your values.
#  Never commit your actual .env file.
# ============================================================

# ── Exchange ──────────────────────────────────────────────
EXCHANGE=kucoin                  # binance | kucoin | bybit

# Binance
BINANCE_API_KEY=
BINANCE_SECRET=
BINANCE_TESTNET=false

# Bybit
BYBIT_API_KEY=
BYBIT_SECRET=
BYBIT_TESTNET=false

# KuCoin
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSWORD=

# Alpaca (stocks)
ALPACA_API_KEY=
ALPACA_SECRET=
ALPACA_PAPER=true

# ── Trading ───────────────────────────────────────────────
TRADING_MODE=paper               # paper | live
MARKET_TYPE=futures              # futures | spot
MARGIN_MODE=isolated             # isolated | cross
SYMBOL=BTC/USDT
SYMBOLS=BTC/USDT,ETH/USDT
PAPER_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
TIMEFRAME=30m
LEVERAGE=3
INITIAL_CAPITAL=50

# ── Risk Management ───────────────────────────────────────
MAX_RISK_PER_TRADE=0.05          # fraction of capital (0.05 = 5%)
MAX_DAILY_DRAWDOWN=0.08          # fraction of capital (0.08 = 8%)
MAX_TRADES_PER_DAY=6
MAX_CONSEC_LOSSES=5

# ── Signal & Fusion ───────────────────────────────────────
FUSION_THRESHOLD=0.19
MIN_RR_RATIO=2.0
WEIGHT_REGIME=0.18
WEIGHT_SENTIMENT=0.12
WEIGHT_WHALE=0.10
WEIGHT_LIQUIDATION=0.25
WEIGHT_ENTRY=0.35

# ── ATR Exit Levels ───────────────────────────────────────
ATR_SL_MULT=1.2
ATR_TP1_MULT=1.2
ATR_TP2_MULT=2.2
TP1_EXIT_PCT=0.65
TP2_EXIT_PCT=0.35
STOP_LOSS_PCT=0.007
TAKE_PROFIT_PCT=0.0175

# ── Telegram Alerts ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_ON_SIGNAL=true
ALERT_ON_TRADE=true
ALERT_ON_DAILY_SUMMARY=true
ALERT_ON_OPTIMIZATION=true

# ── Sentiment / API Keys ──────────────────────────────────
SENTIMENT_MODEL=vader            # vader | finbert
GEMINI_API_KEY=
CRYPTOCOMPARE_KEY=
ETHERSCAN_KEY=
COINGLASS_KEY=
CRYPTOQUANT_KEY=
POLYGON_KEY=

# ── Optimization ─────────────────────────────────────────
OPTUNA_TRIALS=60
OPTUNA_TIMEOUT_SEC=420
OPTUNA_METRIC=target_150
OPTUNA_DATA_CANDLES=1500

# ── Auto Symbol Selection ─────────────────────────────────
AUTO_SYMBOL_SELECTION=false
AUTOSCAN_INTERVAL_SEC=900
AUTOSCAN_TOP_N=5
ROTATOR_MIN_SCORE=0.55
ROTATOR_TRADE_ONLY_TOP_N=3

# ── Memory ────────────────────────────────────────────────
MEMORY_ENABLED=true
MEMORY_WEIGHT=0.15
MEMORY_MIN_TRADES=5

# ── Dashboard / Server ────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
